@import "~/.config/rofi/themes/dragon.rasi"

mainbox {
    children: [ listview ];
}

window {
    width: 15%;
    padding: 7px;
    border-radius: 22px;
}

listview {
    lines: 5;
    cycle: true;
    spacing: 8px;
    dynamic: false;
    fixed-height: true;
}

element {
    padding: 10px 20px;
    border-radius: 999px;
    children: [ element-text ];
}

element-text {
    horizontal-align: 0.0;
}