# Active theme — managed by theme-apply.sh, do not edit manually.
# Change the theme in ~/.config/dwm-titus/themes.toml instead.
#theme = Snazzy Soft
#theme = urban
theme = Catppuccin Mocha
#theme = Relaxed

window-theme = ghostty
window-height = 35
window-width = 100
background-opacity = 0.4
font-family = JetBrains Mono Nerd Font
font-family-bold = JetBrains Mono Nerd Font
font-family-italic = JetBrains Mono Nerd Font
font-family-bold-italic = JetBrains Mono Nerd Font
font-size = 12
gtk-titlebar = false
confirm-close-surface = false
cursor-style = block

#keybind = ctrl+up=scroll_page_lines:5
#keybind = ctrl+down=scroll_page_lines:-5 

keybind = ctrl+up=scroll_page_up
keybind = ctrl+down=scroll_page_down

async-backend = epoll